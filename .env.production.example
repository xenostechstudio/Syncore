################################################################################
# Production environment template for Syncore.
#
# Copy to `.env` on the production host and fill in the marked placeholders.
# DO NOT commit a populated copy.
#
# Differences from .env.example (the dev template):
#   - APP_DEBUG=false               (never expose stack traces in prod)
#   - APP_ENV=production            (drives XenditWebhookController gating
#                                    and other "are we in prod?" checks)
#   - DB_CONNECTION=pgsql           (SQLite is dev/tests only)
#   - QUEUE_CONNECTION=redis        (database queue serializes on every job)
#   - CACHE_STORE=redis             (database cache serializes on every read)
#   - SESSION_DRIVER=redis          (same reasoning)
#   - MAIL_MAILER=smtp              (log mailer silently drops email in prod)
#   - LOG_CHANNEL=daily, LOG_LEVEL=warning (no debug noise, rotating files)
#   - XENDIT_IS_PRODUCTION=true     (uses live Xendit endpoints + token)
#
# Required after deploy:
#   php artisan key:generate --force
#   php artisan migrate --force
#   php artisan storage:link
#   php artisan config:cache route:cache view:cache event:cache
#
# Restrict file perms so secrets aren't world-readable:
#   chmod 600 .env
#   chown www-data:www-data .env
################################################################################

APP_NAME="Syncore"
APP_ENV=production
APP_KEY=                          # generate with `php artisan key:generate --force`
APP_DEBUG=false
APP_URL=https://erp.example.com   # MUST be the real public HTTPS URL
APP_TIMEZONE=Asia/Jakarta         # match the org's accounting timezone

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# Logging — daily rotation, warnings and above. Drops INFO chatter that
# would otherwise fill disks within weeks.
LOG_CHANNEL=daily
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# Database — Postgres only in prod.
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1                 # or your managed DB host
DB_PORT=5432
DB_DATABASE=syncore
DB_USERNAME=syncore
DB_PASSWORD=                      # set strong, unique value

# Sessions, cache, queue — Redis. Strongly recommended over the
# `database` defaults from the dev template; the DB queue serializes
# every job through a SELECT FOR UPDATE.
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true        # HTTPS-only cookies in prod

CACHE_STORE=redis
QUEUE_CONNECTION=redis
BROADCAST_CONNECTION=log

FILESYSTEM_DISK=public            # or s3 if attachments go to S3

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=                   # set if Redis auth is enabled
REDIS_PORT=6379

# Mail — SMTP via your provider. Log driver silently drops mail.
MAIL_MAILER=smtp
MAIL_SCHEME=tls
MAIL_HOST=smtp.example.com        # provider's host (Mailgun, SES, etc.)
MAIL_PORT=587
MAIL_USERNAME=                    # provider credentials
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="no-reply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Object storage (optional, only if you move attachments to S3).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-southeast-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Xendit Payment Gateway — production endpoints + signing token.
# The webhook controller refuses requests in production when the token
# is empty (defense against a misconfigured open endpoint), so this
# value is required for live payments to flow.
XENDIT_SECRET_KEY=                # live secret key from Xendit dashboard
XENDIT_PUBLIC_KEY=                # live public key
XENDIT_WEBHOOK_TOKEN=             # callback verification token from
                                  # Xendit → Settings → Webhooks
XENDIT_IS_PRODUCTION=true

# Error monitoring — set the DSN after wiring Sentry / Bugsnag / etc.
# SENTRY_LARAVEL_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0.1
